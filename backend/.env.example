NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# DigitalOcean Managed PostgreSQL (get URI from DO dashboard → Databases → Connection Details)
DATABASE_URL=postgresql://doadmin:[password]@[host]:25060/defaultdb?sslmode=require
DB_SSL=true

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h
CORS_ORIGIN=https://yourdomain.com

# ── DO Spaces File Storage ────────────────────────────────────────────────────
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=rvr-dpr-files
DO_SPACES_REGION=blr1

# ── GST Verification ─────────────────────────────────────────────────────────
GST_API_PROVIDER=govt_portal
# GST_API_KEY=your-paid-api-key-here

# ── Kala AI Agent ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
