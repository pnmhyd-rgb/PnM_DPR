NODE_ENV=development
PORT=3000

# Local PostgreSQL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/rvr_dpr
# DB_SSL=false

# Supabase (paste URI from Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DB_SSL=true

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173

# ── GST Verification API ─────────────────────────────────────────────────────
# govt_portal  — FREE, no API key. Uses India Govt GST portal (gst.gov.in). Default.
# masters_india — Paid. Set GST_API_KEY to your Masters India access token.
# karza         — Paid. Set GST_API_KEY to your Karza API key.
# http_bearer   — Any REST API. Set GST_API_URL (use {gstin} placeholder) + GST_API_KEY.
# mock          — Returns fake data. Use only when offline / no internet.
GST_API_PROVIDER=govt_portal
# GST_API_KEY=your-paid-api-key-here
# GST_API_URL=https://api.mastersindia.co/api/mastersgst/gstin_data

# ── Kala AI Agent ─────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
